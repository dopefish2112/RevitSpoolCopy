<Window x:Class="RevitSpoolCopy.UI.BatchOperationsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Operations" Height="350" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F0F0F0">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Batch Operations" 
                   FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Operation Selection -->
        <GroupBox Grid.Row="1" Header="Select Operation" Margin="0,0,0,12" Padding="12">
            <StackPanel>
                <RadioButton Name="ClearSpoolRadio" Content="Clear Spool" 
                             Margin="0,6" Checked="ClearSpoolRadio_Checked"/>
                <RadioButton Name="SetSpoolRadio" Content="Set Spool to Value" 
                             Margin="0,6" Checked="SetSpoolRadio_Checked"/>
                <RadioButton Name="ReportRadio" Content="Report Summary (no changes)" 
                             Margin="0,6" Checked="ReportRadio_Checked"/>
            </StackPanel>
        </GroupBox>

        <!-- Value Input (for Set Spool) -->
        <Grid Grid.Row="2" Name="ValueInputPanel" Visibility="Collapsed" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Spool Value:" FontWeight="Bold" Margin="0,0,0,6"/>
            <TextBox Grid.Row="1" Name="ValueTextBox" Padding="8" FontSize="12"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="ApplyButton" Content="Apply" 
                    Padding="16,8" Margin="6,0" Click="ApplyButton_Click"
                    Background="#007ACC" Foreground="White" FontWeight="Bold"/>
            <Button Name="CancelButton" Content="Cancel" 
                    Padding="16,8" Margin="6,0" Click="CancelButton_Click"
                    Background="#E0E0E0" Foreground="Black"/>
        </StackPanel>
    </Grid>
</Window>
