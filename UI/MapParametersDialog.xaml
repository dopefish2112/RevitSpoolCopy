<Window x:Class="RevitSpoolCopy.UI.MapParametersDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Map Parameters" Height="400" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#F0F0F0">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="Map Parameters on Selected Parts" 
                   FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- Mappings List -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Source Parameter -->
            <StackPanel Grid.Column="0">
                <TextBlock Text="Source Parameter" FontWeight="Bold" Margin="0,0,0,6"/>
                <ComboBox Name="SourceParameterCombo" Height="32" Margin="0,0,6,0"/>
            </StackPanel>

            <!-- Arrow -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="→" FontSize="20" FontWeight="Bold" TextAlignment="Center"/>
            </StackPanel>

            <!-- Target Parameter -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="Target Parameter" FontWeight="Bold" Margin="0,0,0,6"/>
                <ComboBox Name="TargetParameterCombo" Height="32" Margin="6,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Name="ApplyButton" Content="Apply Mapping"
                    Padding="12,8" Margin="6,0" Click="ApplyButton_Click"
                    Background="#007ACC" Foreground="White" FontWeight="Bold"/>
            <Button Grid.Column="2" Name="CancelButton" Content="Cancel"
                    Padding="12,8" Margin="6,0" Click="CancelButton_Click"
                    Background="#E0E0E0" Foreground="Black"/>
        </Grid>
    </Grid>
</Window>
